{
  "name": "shizuha",
  "version": "0.1.0",
  "description": "Shizuha universal coding agent",
  "type": "module",
  "main": "dist/shizuha.js",
  "bin": {
    "shizuha": "dist/shizuha.js"
  },
  "scripts": {
    "build": "node esbuild.config.js && vite build --config vite.web.config.ts",
    "postbuild": "chmod +x dist/shizuha.js",
    "build:node": "node esbuild.config.js",
    "build:web": "vite build --config vite.web.config.ts",
    "build:public": "node esbuild.config.js --no-claude-code-provider && chmod +x dist/shizuha.js",
    "build:check": "tsc --noEmit",
    "dev": "tsx src/index.ts",
    "dev:web": "vite --config vite.web.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "serve": "tsx src/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@google/generative-ai": "^0.24.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.0",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "diff": "^7.0.0",
    "dompurify": "^3.3.2",
    "fastify": "^5.2.0",
    "glob": "^11.0.0",
    "ink": "^6.8.0",
    "marked": "^14.1.4",
    "marked-terminal": "^7.3.0",
    "openai": "^4.80.0",
    "pdf-parse": "^1.1.4",
    "pino": "^9.6.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "smol-toml": "^1.3.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tiktoken": "^1.0.0",
    "turndown": "^7.2.0",
    "ws": "^8.19.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "esbuild": "^0.25.0",
    "javascript-obfuscator": "^5.3.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.0"
  },
  "license": "AGPL-3.0-or-later"
}
