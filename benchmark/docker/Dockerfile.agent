# Unified agent execution image for benchmarks.
# Agent binaries/source are mounted at runtime — not baked in.
# Provides Node.js 22 + Python 3 + git + common test dependencies.

FROM node:22-bookworm-slim

# System deps: Python 3, git, curl, build essentials for native npm packages
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 python3-pip python3-venv \
        git curl jq \
        build-essential && \
    rm -rf /var/lib/apt/lists/*

# Python test deps (same as eval image for compatibility)
RUN pip3 install --no-cache-dir --break-system-packages \
    pytest pytest-timeout pytest-asyncio \
    flask requests sqlalchemy aiohttp pydantic \
    beautifulsoup4 lxml cryptography \
    httpx celery redis websockets aioresponses \
    aiosqlite

# Git config for bench user (agents may need to commit)
RUN git config --global user.name "bench" && \
    git config --global user.email "bench@test" && \
    git config --global init.defaultBranch main

# Install Codex CLI globally (needed for codex/codex-51max agents)
RUN npm install -g @openai/codex@latest 2>/dev/null || true

# Create home directory for agent auth files
RUN mkdir -p /home/bench && chmod 777 /home/bench
ENV HOME=/home/bench

WORKDIR /workspace

CMD ["bash"]
